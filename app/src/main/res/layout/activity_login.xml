<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/gray"
    android:id="@+id/main_login">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="25dp">


            <LinearLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/logo2"
                    android:layout_width="134dp"
                    android:layout_height="121dp"
                    android:layout_marginRight="60dp"
                    app:srcCompat="@drawable/logo"/>

                <TextView
                    android:id="@+id/nombre_app2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/NombreAplicacion"
                    android:fontFamily="@font/tiro_devanagari_hindi"
                    android:textColor="@color/orange"
                    android:textSize="34sp"
                    android:textStyle="bold"/>
            </LinearLayout>


            <TextView
                android:id="@+id/texto_login"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="@string/texto_login"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:textAlignment="center"
                android:textSize="18sp"
                android:layout_marginBottom="20dp"
                android:textColor="@color/black"/>


            <LinearLayout
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="63dp"
                    android:layout_height="129dp"
                    app:srcCompat="@drawable/iconos"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/usuario_login"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/style_edi_text"
                        android:paddingStart="15dp"
                        android:hint="Usuario"
                        android:textColorHint="@color/black"/>

                    <EditText
                        android:id="@+id/password_login"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/style_edi_text"
                        android:inputType="textPassword"
                        android:paddingStart="15dp"
                        android:hint="Contraseña"
                        android:textColorHint="@color/black"/>
                </LinearLayout>
            </LinearLayout>


            <Button
                android:id="@+id/btn_ingresar"
                android:layout_width="260dp"
                android:layout_height="65dp"
                android:text="@string/btn_login"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:textSize="30sp"
                android:backgroundTint="@color/orange"
                app:strokeColor="@color/white"
                app:strokeWidth="1.5dp"/>


            <TextView
                android:id="@+id/texto2_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recupera_contraseña_login"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:textSize="16sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:textColor="@color/black"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                android:layout_width="352dp"
                android:layout_height="64dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/tiro_devanagari_hindi"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="@string/google_login"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="30dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ico_google1"
                app:iconGravity="textStart"
                app:iconSize="48dp"
                app:iconTint="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:strokeColor="@color/orange"
                app:strokeWidth="1dp" />


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="15dp">

                <TextView
                    android:text="@string/no_tienes_cuenta_home"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/tiro_devanagari_hindi"
                    android:textColor="@color/black"/>

                <Button
                    android:id="@+id/registrate_login"
                    android:text="@string/textoRegistrate"
                    android:fontFamily="@font/tiro_devanagari_hindi"
                    android:textColor="@color/orange"
                    android:textSize="16sp"
                    android:backgroundTint="@color/gray"
                    android:layout_marginStart="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>